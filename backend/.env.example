# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://btl_user:btl_password@localhost:5432/btl_healthcare?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_REFRESH_EXPIRES_IN="30d"

# AI Provider (OpenAI-compatible for text features like symptom extraction)
AI_PROVIDER="openai"
AI_API_KEY="your-api-key"
AI_BASE_URL="https://api.bluesminds.com/v1"
AI_MODEL="gpt-5-mini"
AI_OCR_MODEL="gemini/gemini-3-flash-preview"

# Gemini Live API (voice chat)
# GOOGLE_API_KEY is already defined below — used for both Maps and Gemini Live

# Cloudinary (avatar, prescription images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Payment - VNPAY Sandbox
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/api/v1/payments/vnpay/return"

# Payment - Momo Sandbox
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api"

# Email (for OTP / password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Google Maps (for clinic geolocation)
GOOGLE_MAPS_API_KEY=""

GOOGLE_API_KEY="AIzaSyAxu3R5xFTtKDJAxFXX12lnwW5Tn2uoGRs"

# App
APP_URL="http://localhost:3000"
MOBILE_SCHEME="btlhealthcare"
